{
  "private": true,
  "author": {
    "name": "Contactlab UXD Team",
    "email": "uxd@contactlab.com",
    "homepage": "https://ux.contactlab.com"
  },
  "scripts": {
    "clean": "rimraf ./dist ./index.html ./main.*.{css,js}",
    "typecheck": "tsc --noEmit",
    "lint:css": "stylelint ./src/**/*.scss",
    "lint:src": "eslint . --ext .js,.ts",
    "lint": "run-p lint:**",
    "dev": "parcel ./src/index.pug --port 3333 --cache-dir ./.cache/parcel",
    "prebuild": "npm run clean",
    "build": "parcel build ./src/index.pug --out-dir ./ --no-cache --no-source-maps"
  },
  "prettier": "@giotramu/prettier-config",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@contactlab/ds-tokens": "^2.0.1"
  },
  "devDependencies": {
    "@giotramu/prettier-config": "1.1.2",
    "@giotramu/stylelint-config": "7.0.1",
    "eslint": "7.23.0",
    "eslint-config-contactlab": "6.1.0",
    "eslint-config-prettier": "8.1.0",
    "husky": "6.0.0",
    "lint-staged": "10.5.4",
    "npm-run-all": "4.1.5",
    "parcel": "1.12.3",
    "prettier": "2.2.1",
    "pug": "3.0.2",
    "rimraf": "3.0.2",
    "sass": "1.32.8",
    "stylelint": "13.12.0",
    "stylelint-scss": "3.19.0",
    "typescript": "4.2.3"
  }
}
