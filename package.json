  "scripts": {
    "clean": "rimraf ./dist ./index.html ./main.*.{css,js}",
    "lint:css": "stylelint ./src/**/*.scss",
    "lint:src": "eslint . --ext .js,.ts",
    "lint": "run-p lint:**",
    "dev": "parcel ./src/index.pug --port 3333 --cache-dir ./.cache/parcel",
    "prebuild": "npm run clean",
    "build": "parcel build ./src/index.pug --out-dir ./ --no-cache --no-source-maps"
  },
  "dependencies": {
    "@contactlab/ds-tokens": "^1.4.7"
  },
  "devDependencies": {
    "@giotramu/stylelint-config": "3.1.0",
    "eslint": "7.0.0",
    "eslint-config-contactlab": "4.2.2",
    "eslint-config-prettier": "6.11.0",
    "husky": "4.2.5",
    "npm-run-all": "4.1.5",
    "parcel": "1.12.4",
    "prettier": "2.0.5",
    "pretty-quick": "2.0.1",
    "pug": "2.0.4",
    "rimraf": "3.0.2",
    "sass": "1.26.5",
    "stylelint": "13.3.3",
    "stylelint-scss": "3.17.2",
    "typescript": "3.8.3"
  }
}
